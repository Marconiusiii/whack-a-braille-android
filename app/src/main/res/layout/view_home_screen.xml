<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/homeTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:accessibilityHeading="true"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineMedium" />

        <TextView
            android:id="@+id/homeSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/home_summary"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <TextView
            android:id="@+id/homeTicketsHeadingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:accessibilityHeading="true"
            android:text="@string/tickets_heading"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/homeTicketsValueText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            tools:text="0 tickets saved" />

        <TextView
            android:id="@+id/homePrizeShelfText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="Prize shelf: 0 prizes" />

        <TextView
            android:id="@+id/homeInputModeHeadingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:accessibilityHeading="true"
            android:text="@string/input_mode_heading"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <RadioGroup
            android:id="@+id/inputModeRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/inputModeStandardRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/input_mode_standard" />

            <RadioButton
                android:id="@+id/inputModePerkinsRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/input_mode_perkins" />

            <RadioButton
                android:id="@+id/inputModeBrailleTextRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/input_mode_braille_text" />

            <RadioButton
                android:id="@+id/inputModeBrailleDisplayRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/input_mode_braille_display" />
        </RadioGroup>

        <Button
            android:id="@+id/startGameButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/start_whacking" />

    </LinearLayout>
</ScrollView>
