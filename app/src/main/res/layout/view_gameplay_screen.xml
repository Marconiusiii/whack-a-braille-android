<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/gameplayTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:accessibilityHeading="true"
            android:text="@string/gameplay_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium" />

        <TextView
            android:id="@+id/gameplayScoreText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            tools:text="Score: 0" />

        <TextView
            android:id="@+id/gameplayStreakText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            tools:text="Current streak: 0" />

        <TextView
            android:id="@+id/gameplayAnnouncementHeadingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:accessibilityHeading="true"
            android:text="@string/current_target_heading"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/gameplayAnnouncementText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            tools:text="Waiting to start" />

        <LinearLayout
            android:id="@+id/gameBoardRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="5">

            <TextView
                android:id="@+id/lane0Text"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:text="@string/lane_waiting"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/lane1Text"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:text="@string/lane_waiting"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/lane2Text"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:text="@string/lane_waiting"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/lane3Text"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:text="@string/lane_waiting"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/lane4Text"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@android:color/darker_gray"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:padding="8dp"
                android:text="@string/lane_waiting"
                android:textAlignment="center" />
        </LinearLayout>

        <TextView
            android:id="@+id/gameplayInputHeadingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:accessibilityHeading="true"
            android:text="@string/braille_entry_heading"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/gameplayInputPlaceholderText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/input_placeholder"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <Button
            android:id="@+id/exitRoundButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/finish_round" />

    </LinearLayout>
</ScrollView>
